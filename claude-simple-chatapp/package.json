{
  "name": "claude-simple-chatapp",
  "version": "1.0.0",
  "type": "module",
  "description": "Browser chat experience for Claude",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:client": "vite --port 5173",
    "start": "tsx server/server.ts",
    "build": "vite build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.84",
    "cors": "2.8.6",
    "dotenv": "17.3.1",
    "express": "5.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-use-websocket": "4.13.0",
    "uuid": "13.0.0",
    "ws": "8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "postcss": "8.5.8",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vite": "8.0.3"
  }
}
